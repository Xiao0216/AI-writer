# 应用配置
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=wenshu_ai
DB_SYNCHRONIZE=true
DB_LOGGING=true

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AI模型配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# 向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 知识图谱
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# 模型存储
MODELS_PATH=./engine/models

# MinIO对象存储
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wenshu-ai
MINIO_USE_SSL=false

# 微信登录
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 短信服务
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# 支付
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=

# 区块链存证
BLOCKCHAIN_API_KEY=
BLOCKCHAIN_API_URL=
